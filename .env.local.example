# Activable local development environment configuration
# Copy this file to .env.local and adjust as needed for your setup
# Never commit .env.local — it contains credentials

# ===== Database (Postgres + Apache AGE) =====
# Running in Docker Compose on localhost:5433
ACTIVABLE_DB_HOST=localhost
ACTIVABLE_DB_PORT=5433
ACTIVABLE_DB_USER=activable
ACTIVABLE_DB_PASSWORD=activable_dev
ACTIVABLE_DB_NAME=activable
ACTIVABLE_DB_URL=postgres://activable:activable_dev@localhost:5433/activable?sslmode=disable
AGE_TEST_URL=postgres://activable:activable_dev@localhost:5433/activable?sslmode=disable
ACTIVABLE_POOL_SIZE=10

# ===== Graph Database (Apache AGE) =====
ACTIVABLE_GRAPH_NAME=cloud

# ===== AWS Configuration (Floci Emulator) =====
# Floci runs in Docker Compose on localhost:4566
# All AWS services (IAM, STS, S3, EC2, Lambda) are emulated locally
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ENDPOINT_URL_IAM=http://localhost:4566
AWS_ENDPOINT_URL_STS=http://localhost:4566
AWS_ENDPOINT_URL_S3=http://localhost:4566
AWS_ENDPOINT_URL_EC2=http://localhost:4566
AWS_ENDPOINT_URL_LAMBDA=http://localhost:4566

# AWS region for local testing
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Mock credentials (no real AWS access — floci accepts any credentials)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=test

# ===== Ingestion Configuration =====
# Settings for the ingestion pipeline
ACTIVABLE_BATCH_SIZE=500
ACTIVABLE_REGIONS=us-east-1
ACTIVABLE_LOCAL_DEV=1

# ===== GraphQL API (when running outside Kubernetes) =====
# If running the Go server locally instead of in K8s, use these settings
ACTIVABLE_GRAPHQL_BIND=0.0.0.0:8080
ACTIVABLE_GRAPHQL_LOG_LEVEL=debug
