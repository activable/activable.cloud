# Build artifacts (massive — must exclude)
target/
target-linux/
**/target/
# Allow the pre-built cross-compiled binary required by ops/docker/Dockerfile
!target/aarch64-unknown-linux-gnu/release-fast/activable-graphql

# Git
.git/
.gitignore
.gitattributes

# IDE / editor
.idea/
.vscode/
*.swp
.DS_Store

# Plans / docs not needed in image
plans/
docs/
*.md
!README.md

# CI / dev tooling
.github/
.claude/
ops/
scripts/

# Tests
tests/

# Bindings (generated)
bindings/
