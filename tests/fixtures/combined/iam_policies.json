[
  {
    "id": "arn:aws:iam::123456789012:policy/s3-full-access",
    "name": "s3-full-access",
    "resource_type": "Policy",
    "account_id": "123456789012",
    "attributes": {
      "path": "/",
      "policy_document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "s3:*",
            "Resource": "*"
          }
        ]
      }
    }
  },
  {
    "id": "arn:aws:iam::123456789012:policy/dynamodb-read",
    "name": "dynamodb-read",
    "resource_type": "Policy",
    "account_id": "123456789012",
    "attributes": {
      "path": "/",
      "policy_document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": ["dynamodb:GetItem", "dynamodb:Query", "dynamodb:Scan"],
            "Resource": "*"
          }
        ]
      }
    }
  },
  {
    "id": "arn:aws:iam::123456789012:policy/ec2-read",
    "name": "ec2-read",
    "resource_type": "Policy",
    "account_id": "123456789012",
    "attributes": {
      "path": "/",
      "policy_document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": ["ec2:Describe*"],
            "Resource": "*"
          }
        ]
      }
    }
  },
  {
    "id": "arn:aws:iam::123456789012:policy/lambda-invoke",
    "name": "lambda-invoke",
    "resource_type": "Policy",
    "account_id": "123456789012",
    "attributes": {
      "path": "/",
      "policy_document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "lambda:InvokeFunction",
            "Resource": "*"
          }
        ]
      }
    }
  },
  {
    "id": "arn:aws:iam::123456789012:policy/logs-write",
    "name": "logs-write",
    "resource_type": "Policy",
    "account_id": "123456789012",
    "attributes": {
      "path": "/",
      "policy_document": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
            "Resource": "*"
          }
        ]
      }
    }
  }
]
